# Server Configuration
PORT=3001
NODE_ENV=development

# Kie.ai (AI video generation)
# Get from: https://kie.ai/
KIE_API_KEY=your_kie_api_key_here
KIE_API_BASE_URL=https://kieai.erweima.ai

# Clerk (Authentication)
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...   # optional — only needed for Clerk webhooks

# Supabase (Database & Storage)
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe (Payments)
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_PRICE_ID=price_...   # Basic plan ($10 / 10 credits)
STRIPE_PRO_PRICE_ID=price_...     # Pro plan ($25 / 30 credits)

# CORS & Client URL
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173   # comma-separated for multiple origins

# Resend (Transactional Email) — optional
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Proxy (set to "true" if behind nginx/Cloudflare in production)
TRUST_PROXY=false

# Rate Limiting — defaults shown, override as needed
# RATE_LIMIT_API_MAX=100
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_GENERATION_MAX=5
# RATE_LIMIT_GENERATION_WINDOW_MS=60000
# RATE_LIMIT_UPLOAD_MAX=10
# RATE_LIMIT_UPLOAD_WINDOW_MS=60000
# RATE_LIMIT_WEBHOOK_MAX=30
# RATE_LIMIT_WEBHOOK_WINDOW_MS=60000
